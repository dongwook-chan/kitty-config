# zsh-shift-select
source ~/.zsh/zsh-shift-select/zsh-shift-select.plugin.zsh

# Copy selected region to system clipboard (Cmd+C in shift-select mode)
function copy-region-to-clipboard() {
	zle copy-region-as-kill -w
	local encoded=$(printf '%s' "$CUTBUFFER" | base64)
	printf '\e]52;c;%s\a' "$encoded"
	zle deactivate-region -w
	zle -K main
}
zle -N copy-region-to-clipboard
bindkey -M shift-select '\e[67;9u' copy-region-to-clipboard
# Ignore the sequence in normal mode (sent by kitty combine with copy_to_clipboard)
function noop() { }
zle -N noop
bindkey -M emacs '\e[67;9u' noop

# Select all (Cmd+A)
function select-all() {
	CURSOR=0
	zle set-mark-command -w
	CURSOR=${#BUFFER}
	zle -K shift-select
}
zle -N select-all
bindkey -M emacs '\e[65;9u' select-all
bindkey -M shift-select '\e[65;9u' select-all

# Shift-select to beginning/end of line (Cmd+Shift+Left/Right)
function shift-select::select-beginning-of-line() {
	if (( !REGION_ACTIVE )); then
		zle set-mark-command -w
		zle -K shift-select
	fi
	zle beginning-of-line -w
}
zle -N shift-select::select-beginning-of-line

function shift-select::select-end-of-line() {
	if (( !REGION_ACTIVE )); then
		zle set-mark-command -w
		zle -K shift-select
	fi
	zle end-of-line -w
}
zle -N shift-select::select-end-of-line

bindkey -M emacs '\e[72;10u' shift-select::select-beginning-of-line
bindkey -M shift-select '\e[72;10u' shift-select::select-beginning-of-line
bindkey -M emacs '\e[69;10u' shift-select::select-end-of-line
bindkey -M shift-select '\e[69;10u' shift-select::select-end-of-line
